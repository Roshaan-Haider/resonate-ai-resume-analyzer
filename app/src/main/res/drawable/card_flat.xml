<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer 1: furthest, most spread, most transparent -->
    <item android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A000000" />
            <corners android:radius="@dimen/radius_lg" />
        </shape>
    </item>

    <!-- Shadow layer 2: closer, tighter, slightly darker -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <corners android:radius="@dimen/radius_lg" />
        </shape>
    </item>

    <!-- The actual card surface, on top -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke
                android:width="1dp"
                android:color="@color/border_subtle" />
        </shape>
    </item>

</layer-list>