<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ZONE 1: Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_xxl"
            android:paddingBottom="@dimen/space_xl">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:contentDescription="Resonate logo"
                    android:src="@drawable/logo_cube" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resonate"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_h1"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="AI-powered resume feedback, instantly"
                android:textColor="#D9FFFFFF"
                android:textSize="@dimen/text_body" />

        </LinearLayout>

        <!-- ZONE 2: Input card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_lg"
            android:background="@drawable/card_flat"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Resume"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etResumeInput"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@null"
                android:gravity="top|start"
                android:hint="Paste your resume text here..."
                android:inputType="textMultiLine"
                android:maxLength="5000"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:gravity="end"
                android:text="0/5000"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label" />

        </LinearLayout>

        <!-- ZONE 3: Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xl"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/button_secondary"
                android:text="Clear"
                android:textAllCaps="false"

                android:textColor="@color/text_secondary" />


            <Button
                android:id="@+id/btnAnalyze"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:background="@drawable/button_primary"
                android:text="Analyze Resume"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>