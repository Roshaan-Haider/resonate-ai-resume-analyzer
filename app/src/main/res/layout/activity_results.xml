<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ZONE 1: Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_xxl"
            android:paddingBottom="@dimen/space_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Results"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_h1"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="Here's how your resume scored"
                android:textColor="#D9FFFFFF"
                android:textSize="@dimen/text_body" />

        </LinearLayout>

        <!-- ZONE 2: Score card (glass style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_lg"
            android:background="@drawable/card_glass"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OVERALL SCORE"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="7/10"
                android:textColor="@color/accent_primary"
                android:textSize="@dimen/text_display"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ZONE 3: Strengths card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md"
            android:background="@drawable/card_flat"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  Strengths"
                android:textColor="@color/status_success"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStrengths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

        <!-- ZONE 4: Weaknesses card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md"
            android:background="@drawable/card_flat"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  Weaknesses"
                android:textColor="@color/status_warning"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWeaknesses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

        <!-- ZONE 5: Suggestions card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md"
            android:background="@drawable/card_flat"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  ATS Suggestions"
                android:textColor="@color/accent_primary"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

        <!-- ZONE 6: Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xl"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCopyResults"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/button_secondary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                android:text="Copy"
                android:textAllCaps="false"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnAnalyzeAnother"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:background="@drawable/button_primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                android:text="Analyze Another"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>